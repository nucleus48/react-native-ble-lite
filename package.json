{
  "name": "react-native-ble-lite",
  "version": "1.0.0",
  "description": "Basic BLE central and peripheral functionality",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "expo-module build",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "prepare": "expo-module prepare",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-module",
    "bluetooth",
    "ble",
    "bluetooth-low-energy",
    "central",
    "peripheral",
    "advertising",
    "scanning",
    "ios",
    "android",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nucleus48/react-native-ble-lite.git"
  },
  "bugs": {
    "url": "https://github.com/nucleus48/react-native-ble-lite/issues",
    "email": "nucleuserumagborie@gmail.com"
  },
  "author": "nucleus48 <nucleuserumagborie@gmail.com>",
  "license": "ISC",
  "homepage": "https://github.com/nucleus48/react-native-ble-lite#readme",
  "devDependencies": {
    "@expo/npm-proofread": "^1.0.1",
    "@types/react": "~19.1.1",
    "expo": "^55.0.5",
    "expo-module-scripts": "^55.0.2",
    "react-native": "0.82.1"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ]
    ]
  }
}
